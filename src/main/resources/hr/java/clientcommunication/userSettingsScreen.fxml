<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" spacing="10" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="hr.java.clientcommunication.controller.SettingsScreenController">

    <!-- Menu at the very top -->
    <fx:include source="menu.fxml" />

    <!-- Main layout content -->
    <GridPane prefHeight="611.0" prefWidth="1065.0">
        <columnConstraints>
            <ColumnConstraints hgrow="SOMETIMES" prefWidth="535.0" />
            <ColumnConstraints hgrow="SOMETIMES" prefWidth="530.0" />
        </columnConstraints>
        <rowConstraints>
            <RowConstraints prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints prefHeight="30.0" vgrow="SOMETIMES" />
        </rowConstraints>

        <children>
            <Label text="User Information" GridPane.columnSpan="2" GridPane.halignment="CENTER" GridPane.valignment="BOTTOM">
                <font>
                    <Font name="Consolas" size="24.0" />
                </font>
            </Label>

            <Label text="Name" GridPane.halignment="RIGHT" GridPane.rowIndex="1">
                <GridPane.margin><Insets right="5.0" /></GridPane.margin>
                <font><Font size="18.0" /></font>
            </Label>

            <Label text="Birth Date" GridPane.halignment="RIGHT" GridPane.rowIndex="2">
                <GridPane.margin><Insets right="5.0" /></GridPane.margin>
                <font><Font size="18.0" /></font>
            </Label>

            <Label text="Username" GridPane.halignment="RIGHT" GridPane.rowIndex="4">
                <GridPane.margin><Insets right="5.0" /></GridPane.margin>
                <font><Font size="18.0" /></font>
            </Label>

            <!-- Preferences Label -->
            <Label text="Role" GridPane.halignment="RIGHT" GridPane.rowIndex="5" GridPane.valignment="CENTER">
                <font><Font size="18.0" /></font>
            </Label>
         <Label fx:id="nameLabel" text="Label" GridPane.columnIndex="1" GridPane.rowIndex="1" />
         <Label fx:id="birthDateLabel" text="Label" GridPane.columnIndex="1" GridPane.rowIndex="2" />
         <Label fx:id="usernameLabel" text="Label" GridPane.columnIndex="1" GridPane.rowIndex="4" />
         <Label fx:id="roleLabel" text="Label" GridPane.columnIndex="1" GridPane.rowIndex="5" />
        </children>
    </GridPane>
</VBox>
